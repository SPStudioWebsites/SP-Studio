# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (auf jeder Ebene ignorieren – hier steckt die 100 MB+ SWC-Binary drin)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js build output & caches
.next/
/out/
.turbo/
.swc/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / OS
.idea/
*.swp
*.swo

# large / temporary media (nicht versehentlich einchecken)
*.zip
*.tar
*.tar.gz
*.mov
*.mp4
*.node
